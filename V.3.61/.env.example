# Supabase — Cuenta y paletas en la nube
# Crea un proyecto en https://supabase.com y copia aquí la URL y la clave anónima (anon public).
# Luego renombra este archivo a .env (o añade estas variables en Vercel → Settings → Environment Variables).

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anon-publica

# Opcional: emails que pueden ver "Análisis investigación" y exportar a Excel (separados por coma).
# Por defecto la app usa robi20leoc@gmail.com si no se define.
# VITE_RESEARCH_ADMIN_EMAILS=robi20leoc@gmail.com
